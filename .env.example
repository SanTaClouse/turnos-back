PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=turnosporwsp

# WhatsApp Business API
WHATSAPP_API_TOKEN=your_access_token_here
WHATSAPP_PHONE_ID=your_phone_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token_secreto

# ───────────────────────── Mercado Pago / Billing ─────────────────────────
# Access token de TU cuenta de Mercado Pago (todos los tenants te pagan a vos).
# Sacalo en https://www.mercadopago.com.ar/developers/panel/app → Credenciales.
# Usá las de TEST para probar y las de PRODUCCIÓN cuando salgas a la calle.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
# Secret de la firma del webhook (panel de MP → Webhooks → "Clave secreta").
MP_WEBHOOK_SECRET=tu_secret_de_webhook
# Monto y moneda del plan mensual.
MP_PLAN_AMOUNT=20000
MP_PLAN_CURRENCY=ARS
# URL pública del frontend (a donde vuelve MP tras el pago) y del backend
# (a donde MP manda los webhooks). En prod poné los dominios reales.
APP_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000
